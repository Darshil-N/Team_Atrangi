# ─────────────────────────────────────────────────────────
# HC01 Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# Supabase (get from https://app.supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key-here

# Google Gemini (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local — must be running before starting the backend)
# Install: https://ollama.com/download
# Model:   ollama pull phi3:mini
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_NUM_CTX=4096        # caps KV cache to bound VRAM usage
OLLAMA_NUM_GPU=99          # forces all model layers onto GPU

# ChromaDB (local vector store — path is relative to backend/ dir)
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=clinical_guidelines
